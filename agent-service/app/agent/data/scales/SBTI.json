  "scoring": {
    "type": "multi_dimension",
    "note": "SBTI采用五大模型十五维度评分，结果为趣味人格标签，非标准心理量表。纯娱乐。",

    "step1_per_question": {
      "description": "每题3个选项，value = 1 / 2 / 3（具体值由题目定义，部分题目反向计分）",
      "reverse_questions": [14, 22],
      "reverse_note": "反向题的选项 value 为 3/2/1（第一个选项=3），其余题为 1/2/3。q14 认同边界=H=3；q22 乐观接受=H=3。",
      "gate_question": {
        "id": 4,
        "description": "爱好门：不参与维度计分，但选择「饮酒」触发 DRUNK 特殊规则"
      }
    },

    "step2_dimension_score": {
      "description": "每个维度有2道题，两题 value 相加得 raw score（范围 2-6）",
      "mapping": {
        "L": "raw ≤ 3",
        "M": "raw = 4",
        "H": "raw ≥ 5"
      }
    },

    "step3_pattern": {
      "description": "按固定顺序拼出15位 L/M/H pattern",
      "order": ["S1", "S2", "S3", "E1", "E2", "E3", "A1", "A2", "A3", "Ac1", "Ac2", "Ac3", "So1", "So2", "So3"],
      "example": "HHH-HMH-MHH-HHH-MHM"
    },

    "step4_match_personality": {
      "description": "与25个标准人格的 pattern 计算曼哈顿距离，取最小者",
      "distance_encoding": {"L": 1, "M": 2, "H": 3},
      "similarity_formula": "max(0, round((1 - distance / 30) * 100))",
      "max_distance_note": "15个维度，每维度最大差值2（L vs H），理论最大距离=30"
    },

    "special_rules": {
      "priority": "特殊规则优先级最高，在 step4 之前判断",
      "DRUNK": {
        "trigger": "q4 选择「饮酒」→ 追问 → 特定答案",
        "result": "直接判定为 DRUN-K 人格"
      },
      "HHHH": {
        "trigger": "step4 相似度 < 60%",
        "result": "兜底判定为 HHHH 人格"
      }
    },

    "dimension_question_map": {
