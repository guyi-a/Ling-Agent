# Environment Configuration Example
# Copy this file to .env and fill in your actual values

PORT=9000
DEBUG=True

# Database Configuration
DATABASE_URL=sqlite:///./app.db

# LLM Configuration (智谱 GLM)
LLM_API_KEY=your_zhipu_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 推荐模型：glm-4.7（支持工具调用，200K 上下文）
# 其他可选：glm-5.1, glm-5, glm-4.7-flashx（轻量高速）
LLM_MODEL=glm-4.7

# RAG Embedding (DashScope)
RAG_API_KEY=your_dashscope_api_key_here
RAG_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Workspace Configuration
# Directory for user-uploaded files and agent-generated outputs (per session)
WORKSPACE_ROOT=./workspace

# Logging Configuration
LOG_LEVEL=INFO

# Langfuse Observability (optional)
# Sign up at https://cloud.langfuse.com or self-host
# Leave empty to disable tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
